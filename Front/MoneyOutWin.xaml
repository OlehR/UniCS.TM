<Window x:Class="Front.MoneyOutWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Front.ViewModels"
        mc:Ignorable="d"
        Title="MoneyOutWin" Height="450" Width="800">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#4A6CF7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A5CE5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BBBFD6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#22C55E"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#16A34A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StyledTextBox" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#4A6CF7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <local:InverseBoolConverter     x:Key="InverseBool"/>
        <local:ConfirmedRowBrushConverter x:Key="ConfirmedRowBrush"/>
        <local:TopAmountBorderBrushConverter x:Key="TopAmountBorderBrush"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════
     ВЕРХНЯ ПОЛОСКА
     Колонки: [назва/сума *] [на касі 120] [поле 130] [кнопка 120]
════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
        BorderBrush="#E5E7EB" BorderThickness="0,0,0,2"
        Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <!-- Сума (колонка 0) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="4,0,0,0">
                    <TextBlock Text="Сума:" FontSize="13" Foreground="#6B7280"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding TotalSum, StringFormat={}{0:F2} ₴}"
                       FontSize="20" FontWeight="Bold" Foreground="#111827"
                       VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Колонка 1: порожня — вирівнювання із "На касі" -->

                <!-- Поле вводу суми (колонка 2) -->
                <TextBox Grid.Column="2"
                 Style="{StaticResource StyledTextBox}"
                 Text="{Binding TopAmount, UpdateSourceTrigger=PropertyChanged}"
                 BorderBrush="{Binding TopAmountIsValid, Converter={StaticResource TopAmountBorderBrush}}"
                 ToolTip="Введіть суму — має бути менше загальної"
                 Height="34" VerticalAlignment="Center"/>

                <!-- Кнопка підтвердити (колонка 3) -->
                <Button Grid.Column="3"
                Content="✓ Підтвердити"
                Style="{StaticResource PrimaryButton}"
                Command="{Binding ConfirmTopCommand}"
                Height="34" VerticalAlignment="Center"
                Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
     ТАБЛИЦЯ
════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="16,12,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовки — ті самі ColumnDefinitions -->
            <Border Grid.Row="0" Background="#4A6CF7"
            CornerRadius="8,8,0,0" Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Товар"     Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Grid.Column="1" Text="На касі"   Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Кількість" Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Дія"       Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Рядки -->
            <Border Grid.Row="1" Background="White"
            BorderBrush="#E5E7EB" BorderThickness="1,0,1,1"
            CornerRadius="0,0,8,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,7"
                                Background="{Binding IsConfirmed, Converter={StaticResource ConfirmedRowBrush}}"
                                BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="13" Foreground="#111827"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="1"
                                           Text="{Binding AvailableQty, StringFormat={}{0:F2}}"
                                           FontSize="13" Foreground="#374151"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontWeight="Medium"/>

                                        <TextBox Grid.Column="2"
                                         Style="{StaticResource StyledTextBox}"
                                         Text="{Binding InputQty, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsConfirmed, Converter={StaticResource InverseBool}}"
                                         Height="30" VerticalAlignment="Center"/>

                                        <Button Grid.Column="3"
                                        Content="✓"
                                        Style="{StaticResource RowButton}"
                                        Command="{Binding DataContext.ConfirmRowCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding IsConfirmed, Converter={StaticResource InverseBool}}"
                                        Height="30" Width="60"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
